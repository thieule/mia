# Copy to `.env` in this directory (ai-tech/). Not committed.
# Optional vars: see ../mia/EXAMPLE_.env (Jenkins, Atlassian, …).

# --- OpenRouter ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# --- Web search (Brave in config) ---
BRAVE_API_KEY=

# --- ai-tools MCP (registry + pytest) — required for bundled local MCPs ---
AI_TOOL_SECRET=change-me-to-a-long-random-secret

# --- GitHub MCP (Copilot endpoint by default; use PAT in GITHUB_TOKEN) ---
GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/
GITHUB_TOKEN=
# Optional GitHub App instead of token (see start.py):
# GITHUB_APP_ID=
# GITHUB_APP_INSTALLATION_ID=
# GITHUB_APP_PRIVATE_KEY_B64=

# --- Pytest MCP: where JSON run reports are stored (default: workspace/agent/test-runs/) ---
# Leave unset or empty to use that default. Uncomment to override:
# TEST_RUNS_PATH_MIA_TECH=

# --- Discord (Mia tech bot — separate from other deployments) ---
DISCORD_BOT_TOKEN_MIA_TECH=
DISCORD_ADMIN_USER_IDS=
