# Copy to `.env` in this directory (ai-tech/). Not committed.
# Optional vars: see ../mia/EXAMPLE_.env (Jenkins, Atlassian, …).

# --- OpenRouter ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# --- Google Gemini (tùy chọn; cùng kiểu providers.gemini.apiKey như openrouter) ---
# Khi dùng Gemini: trong config.json đổi agents.defaults thành "provider": "gemini", "model": "${GEMINI_MODEL}".
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Web search (Brave in config) ---
BRAVE_API_KEY=

# --- ai-tools MCP (registry + pytest) — required for bundled local MCPs ---
AI_TOOL_SECRET=change-me-to-a-long-random-secret

# --- GitHub MCP (preferred for GitHub-hosted Git: issues, PRs, contents, branches) ---
# Copilot endpoint example; use PAT in GITHUB_TOKEN. Fall back to `exec git` only for local-only flows.
GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/
GITHUB_TOKEN=
# Optional GitHub App instead of token (see start.py):
# GITHUB_APP_ID=
# GITHUB_APP_INSTALLATION_ID=
# GITHUB_APP_PRIVATE_KEY_B64=

# --- Pytest MCP: where JSON run reports are stored (default: workspace/agent/test-runs/) ---
# Leave unset or empty to use that default. Uncomment to override:
# TEST_RUNS_PATH_MIA_TECH=

# --- Agile / API Center: async chat reply when working-queue finishes after HTTP wait timeout ---
# Must match API_CENTER_WORKING_QUEUE_INGEST_SECRET on API Center. POST URL is the API Center base + path below.
# WORKING_QUEUE_REPLY_INGEST_URL=http://127.0.0.1:18881/v1/internal/working-queue-reply
# WORKING_QUEUE_REPLY_INGEST_SECRET=same-as-API_CENTER_WORKING_QUEUE_INGEST_SECRET

# --- Linux deploy MCP (optional): SSH/rsync only to hosts listed here ---
# LINUX_DEPLOY_ALLOWED_HOSTS=staging.example.com,10.0.0.5
# LINUX_DEPLOY_DEFAULT_USER=deploy
# LINUX_DEPLOY_IDENTITY_FILE=/path/on/gateway/id_ed25519

# --- Discord (Mia tech bot — separate from other deployments) ---
DISCORD_BOT_TOKEN_MIA_TECH=
DISCORD_ADMIN_USER_IDS=
