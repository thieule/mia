# Copy to `.env` in this directory (ai-dev/). Not committed.
# Optional vars: see ../core/EXAMPLE_.env (Jenkins, Atlassian, …).

# --- OpenRouter ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# --- Google Gemini (optional) ---
# When using Gemini: in config.json set "provider": "gemini", "model": "${GEMINI_MODEL}".
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Web search (Brave in config) ---
BRAVE_API_KEY=

# --- ai-tools MCP (registry + pytest) ---
AI_TOOL_SECRET=change-me-to-a-long-random-secret

# --- GitHub MCP (Copilot endpoint by default) ---
GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/
GITHUB_TOKEN=
# GITHUB_APP_ID=
# GITHUB_APP_INSTALLATION_ID=
# GITHUB_APP_PRIVATE_KEY_B64=

# --- Pytest MCP: JSON reports (default: workspace/agent/test-runs/) ---
# TEST_RUNS_PATH_MIA_DEV=

# --- Discord (Mia dev — separate from other deployments) ---
DISCORD_BOT_TOKEN_MIA_DEV=
DISCORD_ADMIN_USER_IDS=
