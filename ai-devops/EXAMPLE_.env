# Copy to `.env` in this directory (ai-devops/). Not committed.

# --- OpenRouter ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# --- Google Gemini (optional; same pattern as openrouter in providers) ---
# To use: set "provider": "gemini" and "model": "${GEMINI_MODEL}" in config.json.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Web search (Brave in config) ---
BRAVE_API_KEY=

# --- ai-tools MCP (registry + pytest) — required for bundled local MCPs ---
AI_TOOL_SECRET=change-me-to-a-long-random-secret

# --- GitHub MCP (CI / workflows; Copilot endpoint by default) ---
GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/
GITHUB_TOKEN=
# Optional GitHub App instead of token (see start.py):
# GITHUB_APP_ID=
# GITHUB_APP_INSTALLATION_ID=
# GITHUB_APP_PRIVATE_KEY_B64=

# --- Pytest MCP: JSON test reports (default: workspace/agent/test-runs/) ---
# TEST_RUNS_PATH_MIA_DEVOPS=

# --- Linux deploy MCP (SSH / rsync to allowlisted servers only) ---
# Comma-separated hostnames or IPs. Empty = all ssh_exec / rsync_upload calls refused.
LINUX_DEPLOY_ALLOWED_HOSTS=
# If host is passed without user@, prepend this SSH user:
LINUX_DEPLOY_DEFAULT_USER=
# Optional: private key path on the gateway host for ssh -i
# LINUX_DEPLOY_IDENTITY_FILE=
# LINUX_DEPLOY_STRICT_HOST_KEY_CHECKING=accept-new
# LINUX_DEPLOY_SSH_PORT=

# --- Atlassian (optional) — if you add atlassian MCP to config, set these ---
# See ai-tools/launchers/run_atlassian_mcp.py and team docs
# JIRA_MCP_*, CONFLUENCE_*, or project-specific

# --- Discord (Mia DevOps bot) ---
DISCORD_BOT_TOKEN_MIA_DEVOPS=
DISCORD_ADMIN_USER_IDS=
