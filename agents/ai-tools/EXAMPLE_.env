# ai-tools environment variables.
# These must ALSO be present in mia/.env so start_flo.py can resolve
# ${VAR} references inside config/flo.config.json and pass them to MCP subprocesses.

# --- Shared auth secret (agent <-> tools) ---
# Generate: python -c "import secrets; print(secrets.token_hex(20))"
# Same value must be in mia/.env
FLO_TOOL_SECRET=

# --- Atlassian MCP (mcp-atlassian handles both Confluence and Jira) ---

# Confluence base URL e.g. https://yourorg.atlassian.net/wiki
CONFLUENCE_URL=
# Atlassian account email
CONFLUENCE_USERNAME=
# Atlassian API token: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_API_TOKEN=

# Jira base URL e.g. https://yourorg.atlassian.net
JIRA_URL=
# Atlassian account email (usually same as Confluence)
JIRA_USERNAME=
# Atlassian API token (can reuse the same one as Confluence)
JIRA_API_TOKEN=

# READ_ONLY_MODE is hardcoded to true in flo.config.json — do not override here.

# --- pytest runner MCP ---
# Where agent saves generated test suites (default: mia/workspace/agent/tests)
TEST_SUITES_PATH=
# Where test run results/logs are stored (default: mia/workspace/agent/test-runs)
TEST_RUNS_PATH=
