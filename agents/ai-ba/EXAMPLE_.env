# Copy to `.env` in this directory (ai-ba/). Not committed.

# --- OpenRouter ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# --- Google Gemini (optional; same pattern as openrouter in providers) ---
# To use: set "provider": "gemini" and "model": "${GEMINI_MODEL}" in config.json.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Web search (`tools.web.search.provider` in config/config.json) ---
# Providers (mia core): brave | duckduckgo | searxng | tavily | jina | kagi | wikipedia
# Free without key: duckduckgo, wikipedia (encyclopedia-only), searxng (needs SEARXNG_BASE_URL)
BRAVE_API_KEY=
# Optional: Vietnamese wiki etc. — default https://en.wikipedia.org
# WIKIPEDIA_ORIGIN=https://vi.wikipedia.org
# SEARXNG_BASE_URL=https://your-searx.example

# --- ai-tools MCP (registry + pytest) — required for bundled local MCPs ---
AI_TOOL_SECRET=change-me-to-a-long-random-secret

# --- GitHub MCP (Copilot endpoint by default; use PAT in GITHUB_TOKEN) ---
GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/
GITHUB_TOKEN=
# Optional GitHub App instead of token (see start.py):
# GITHUB_APP_ID=
# GITHUB_APP_INSTALLATION_ID=
# GITHUB_APP_PRIVATE_KEY_B64=

# --- Pytest MCP: where JSON run reports are stored (default: workspace/agent/test-runs/) ---
# Leave unset or empty to use that default. Uncomment to override:
# TEST_RUNS_PATH_MIA_BA=

# --- Discord (Mia BA bot — separate from Mia tech and other deployments) ---
DISCORD_BOT_TOKEN_MIA_BA=
DISCORD_ADMIN_USER_IDS=
