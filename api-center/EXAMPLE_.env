# Copy to .env (do not commit secrets)

API_CENTER_CONNECT_SECRET=change-me-long-random-secret

# Same value as WORKING_QUEUE_REPLY_INGEST_SECRET on each Mia gateway that POSTs async chat completions.
# API_CENTER_WORKING_QUEUE_INGEST_SECRET=another-long-random-secret

# API_CENTER_PORT=18881
# API_CENTER_PUBLIC_BASE_URL=localhost:18881
# API_CENTER_AGENTS_FILE=agents.json
# API_CENTER_CATALOG_FILE=agents.catalog.json
# API_CENTER_SESSION_TTL_DAYS=30
# MCP credentials are persisted in data/mcp_credentials.json

# Admin API: tạo/xóa agent, quản lý prompt trong DB (header X-Api-Center-Admin-Secret).
# Bắt buộc nếu dùng /v1/admin/* ; nếu không set, các route admin trả 503.
# API_CENTER_ADMIN_SECRET=another-long-random-admin-secret

# MySQL cho registry agent + prompt (cùng schema Agile hoặc DB riêng). Có thể dùng AGILE_DATABASE_URL thay cho dòng này.
# API_CENTER_AGENT_DB_URL=mysql://user:pass@127.0.0.1:3306/agile_studio

# Callback HTTP đẩy reply agent sang Agile Hub khi MCP/WebSocket không giao được.
# URL đầy đủ (path agent-reply). Cùng máy, Hub cổng 9120:
# API_CENTER_AGILE_REPLY_URL=http://127.0.0.1:9120/api/v1/integrations/api-center/agent-reply
# Phải cùng giá trị với AGILE_AGENT_REPLY_TOKEN trên Agile Studio:
# API_CENTER_AGILE_REPLY_TOKEN=change-me-long-random-shared-with-agile-hub
