# Copy to `.env` in this directory (ai-qc/). Not committed.

# --- OpenRouter ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# --- Google Gemini (optional; same pattern as openrouter in providers) ---
# To use: set "provider": "gemini" and "model": "${GEMINI_MODEL}" in config.json.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Web search (Brave in config) ---
BRAVE_API_KEY=

# --- ai-tools MCP (registry + pytest) ---
AI_TOOL_SECRET=change-me-to-a-long-random-secret

# --- GitHub (issues, Actions, test workflows) ---
GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/
GITHUB_TOKEN=
# GITHUB_APP_ID=
# GITHUB_APP_INSTALLATION_ID=
# GITHUB_APP_PRIVATE_KEY_B64=

# --- Pytest MCP JSON reports (default: workspace/agent/test-runs/) ---
# TEST_RUNS_PATH_MIA_QC=

# Optional: path to test repo / Playwright if you wire custom scripts
# E2E_BASE_URL=https://localhost:3000

# --- Discord (Mia QC bot) ---
DISCORD_BOT_TOKEN_MIA_QC=
DISCORD_ADMIN_USER_IDS=
