# Copy this file to `.env` in the same directory (mia root), then fill in values.
# mia resolves ${VAR} references inside config/flo.config.json from the process environment.
# Run the gateway: python start_flo.py  (from this directory; loads this file automatically)

# --- OpenRouter (LLM) ---
OPENROUTER_API_KEY=
# Model id as shown on OpenRouter (examples: openai/gpt-4o-mini, anthropic/claude-3.5-sonnet)
OPENROUTER_MODEL=openai/gpt-4o-mini

# --- Google Gemini (direct OpenAI-compatible API) ---
# Get a key: https://aistudio.google.com/apikey
# Any one of these is enough; core hydrates providers.gemini from the process env if JSON omits apiKey.
GEMINI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# GOOGLE_API_KEY=
# Example model ids (no OpenRouter prefix): gemini-2.0-flash, gemini-2.5-pro-preview-03-25

# --- Web search ---
# Brave Search API key: https://api.search.brave.com/
BRAVE_API_KEY=

# --- Discord (primary channel) ---
# Bot token from https://discord.com/developers/applications -> Bot -> Reset / copy token
DISCORD_BOT_TOKEN=
# Admin Discord user IDs. Comma-separated is supported.
# Anyone in the channel may talk to the bot; only these IDs should approve protected changes.
DISCORD_ADMIN_USER_IDS=

# --- a-tools shared secret (agent <-> MCP servers) ---
# Generate: python -c "import secrets; print(secrets.token_hex(20))"
FLO_TOOL_SECRET=

# --- Atlassian MCP (Confluence + Jira via mcp-atlassian) ---
# Confluence base URL e.g. https://yourorg.atlassian.net/wiki
CONFLUENCE_URL=
# Atlassian account email
CONFLUENCE_USERNAME=
# Atlassian API token: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_API_TOKEN=

# Jira base URL e.g. https://yourorg.atlassian.net
JIRA_URL=
# Atlassian account email (usually same as Confluence)
JIRA_USERNAME=
# Atlassian API token (can reuse the same one as Confluence)
JIRA_API_TOKEN=

# --- Jenkins MCP plugin (direct) ---
# Base Jenkins URL e.g. https://jenkins.example.com
JENKINS_URL=
# Optional override if the MCP endpoint is exposed on a non-standard path.
# If empty, mia derives: <JENKINS_URL>/mcp-server/mcp
JENKINS_MCP_URL=
# Jenkins username used with API token via HTTP Basic auth
JENKINS_USERNAME=
# Jenkins API token
JENKINS_API_TOKEN=

# --- GitHub MCP (direct github.com) ---
# Optional override. Defaults to GitHub-hosted MCP:
# https://api.githubcopilot.com/mcp/
GITHUB_MCP_URL=
# Optional override for GitHub API base. For github.com keep the default.
GITHUB_API_URL=
# Preferred: GitHub App credentials
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
# Preferred: Base64-encoded GitHub App private key (single line, deployment-friendly)
GITHUB_APP_PRIVATE_KEY_B64=
# Optional: raw PEM text with literal \n escapes
GITHUB_APP_PRIVATE_KEY=
# Fallback only: local file path if you really want to store the key on disk
# Recommended location: secrets/github-app.private-key.pem
GITHUB_APP_PRIVATE_KEY_PATH=
# Fallback: GitHub Personal Access Token. Use read-only scopes for now.
GITHUB_TOKEN=

# --- pytest runner MCP ---
# Where agent saves generated test suites (default: workspace/agent/tests)
TEST_SUITES_PATH=
# Where test run results/logs are stored (default: workspace/agent/test-runs)
TEST_RUNS_PATH=
