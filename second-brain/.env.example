# Sao chép thành .env khi chạy second-brain ngoài Docker.
#
# Ingest GitHub qua SB: commit → task/story, diff ES; có thể giảm tải bằng SECOND_BRAIN_GITHUB_MAX_FILES / MAX_FILE_BYTES (mục GitHub dưới đây).

NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=secondbrain_local

ELASTICSEARCH_URL=http://127.0.0.1:9200

MCP_TRANSPORT=streamable-http
MCP_HOST=127.0.0.1
MCP_PORT=8000
MCP_STATELESS_HTTP=true
MCP_JSON_RESPONSE=true
# Tuỳ chọn: bảo vệ chỉ endpoint MCP (/mcp) — Client gửi Authorization: Bearer <secret> hoặc X-Second-Brain-MCP-Secret.
# SECOND_BRAIN_MCP_SECRET=

# Trùng với AGILE_SECOND_BRAIN_INGEST_SECRET trên Agile Hub (HTTP ingest).
SECOND_BRAIN_INGEST_SECRET=secondbrain_ingest_dev

# Embedding cho Elasticsearch (kNN) — Gemini (bắt buộc cho production).
GEMINI_API_KEY=
# SECOND_BRAIN_GEMINI_EMBED_MODEL=text-embedding-004
# Chiều vector (khớp dense_vector trong ES; đổi dim → cần index mới hoặc reindex).
# SECOND_BRAIN_EMBED_DIM=384
# Chỉ dev/CI không có API key: SECOND_BRAIN_EMBEDDING_FALLBACK=1 (vector deterministic, không phải semantic thật).
# Retry embedding Gemini khi 429 / lỗi tạm (HTTP 5xx): SECOND_BRAIN_EMBED_MAX_RETRIES=3, SECOND_BRAIN_EMBED_RETRY_DELAY_SEC=1.25

# GitHub push → graph CodeFile / Commit / Python CodeFunction (POST /ingest/github-webhook).
# SECOND_BRAIN_GITHUB_WEBHOOK_SECRET=<secret trùng GitHub webhook>
# SECOND_BRAIN_GITHUB_TOKEN=<PAT đọc repo — lấy nội dung file>
# SECOND_BRAIN_GITHUB_REPO_PROJECT_MAP={"myorg/my-repo": 2}
# Hoặc một project mặc định: SECOND_BRAIN_GITHUB_DEFAULT_PROJECT_ID=2
# Quét code trên disk (MCP `brain_scan_local_code`, POST /ingest/local-code-scan) — cùng pipeline phân tích với GitHub.
# Allowlist bắt buộc: `root` phải nằm dưới một trong các gốc (đường dẫn tuyệt đối, comma-separated).
# SECOND_BRAIN_LOCAL_CODE_SCAN_ROOTS=/Users/you/workspace/mia
# Docker Compose: mount repo → /workspace/mia (SECOND_BRAIN_LOCAL_SCAN_HOST_PATH trên host, mặc định .)
# SECOND_BRAIN_LOCAL_SCAN_HOST_PATH=.
# SECOND_BRAIN_GITHUB_MAX_FILES=50
# SECOND_BRAIN_GITHUB_MAX_FILE_BYTES=400000
# SECOND_BRAIN_COMMIT_TASK_PATTERN=(?:task|ticket|tid)\s*[#:_-]?\s*(\d+)
# Story / issue trong commit → (Commit)-[:IMPLEMENTS]->(Story); tuỳ chọn thêm SECOND_BRAIN_COMMIT_FIXES_PATTERN (regex thứ 2).
# SECOND_BRAIN_COMMIT_STORY_PATTERN=(?:story|st)\s*[#:_-]?\s*(\d+)
# SECOND_BRAIN_COMMIT_FIXES_PATTERN=
# Story key kiểu slug Agile (vd hub slug demo → commit chứa demo-12): SECOND_BRAIN_COMMIT_STORY_SLUG=demo
# SECOND_BRAIN_COMMIT_STORY_SLUG=
# brain_github_compare / POST /ingest/github-compare
# SECOND_BRAIN_GITHUB_COMPARE_MAX_FILES=40
# SECOND_BRAIN_GITHUB_COMPARE_MAX_PATCH_BYTES=16000
# Unified diff / điều tra issue → ES label CodeDiff, source_type=code_diff (brain_search_knowledge).
# SECOND_BRAIN_GITHUB_FETCH_DIFF=1
# SECOND_BRAIN_GITHUB_DIFF_MAX_PATCH_BYTES=32000
# SECOND_BRAIN_GITHUB_DIFF_MAX_FILES=80
# touched = chỉ file added/modified/removed trong ingest; full_commit = mọi file đổi trong commit (tới giới hạn).
# SECOND_BRAIN_GITHUB_DIFF_INDEX_SCOPE=touched

# Tuỳ chọn P3: LLM OpenAI-compatible để trích lesson (brain_extract_lesson_from_text).
# SECOND_BRAIN_EXTRACT_LLM_URL=https://api.openai.com/v1
# SECOND_BRAIN_EXTRACT_LLM_KEY=
# SECOND_BRAIN_EXTRACT_LLM_MODEL=gpt-4o-mini
