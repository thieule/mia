# Copy to .env trong thư mục agile-studio (không commit secret thật)

AGILE_DATABASE_URL=mysql+pymysql://app:app@127.0.0.1:3307/agile_studio

# HTTP (tuỳ chọn — mặc định config: host 127.0.0.1, port 9120)
# AGILE_LISTEN_HOST=127.0.0.1
# AGILE_LISTEN_PORT=9120

# JWT (production: đặt AGILE_JWT_SECRET dài, ngẫu nhiên)
# AGILE_JWT_SECRET=change-me
# AGILE_JWT_EXPIRE_MINUTES=10080

# Base URL chat-service — cần để ghi tin nhắn agent (kể cả khi reply tới qua HTTP callback từ API Center).
AGILE_CHAT_SERVICE_URL=http://127.0.0.1:3001

# Bearer khi API Center gọi POST /api/v1/integrations/api-center/agent-reply.
# Phải trùng với API_CENTER_AGILE_REPLY_TOKEN trên process api_center.
AGILE_AGENT_REPLY_TOKEN=change-me-long-random-shared-with-api-center
