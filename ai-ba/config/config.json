{
  "agents": {
    "defaults": {
      "workspace": "./workspace",
      "model": "${GEMINI_MODEL}",
      "provider": "gemini",
      "timezone": "UTC"
    }
  },
  "providers": {
    "openrouter": {
      "apiKey": "${OPENROUTER_API_KEY}"
    },
    "gemini": {
      "apiKey": "${GEMINI_API_KEY}"
    }
  },
  "channels": {
    "discord": {
      "enabled": false,
      "token": "${DISCORD_BOT_TOKEN_MIA_BA}",
      "allowFrom": [
        "*"
      ],
      "adminUserIds": [
        "${DISCORD_ADMIN_USER_IDS}"
      ],
      "groupPolicy": "open",
      "streaming": true,
      "intents": 37377,
      "readReceiptEmoji": "👀",
      "workingEmoji": "📊",
      "workingEmojiDelay": 2.0
    }
  },
  "gateway": {
    "port": 18793
  },
  "working_queue": {
    "enabled": true,
    "interval_s": 3,
    "max_tasks_per_tick": 2
  },
  "tools": {
    "restrictToWorkspace": true,
    "exec": {
      "enable": true,
      "timeout": 180
    },
    "web": {
      "enable": true,
      "search": {
        "provider": "brave"
      }
    },
    "mcpServers": {
      "registry": {
        "command": "python",
        "args": [
          "../ai-tools/registry/server.py"
        ],
        "env": {
          "AI_TOOL_SECRET": "${AI_TOOL_SECRET}"
        }
      },
      "pytest_runner": {
        "command": "python",
        "args": [
          "../ai-tools/servers/pytest_runner/server.py"
        ],
        "env": {
          "AI_TOOL_SECRET": "${AI_TOOL_SECRET}",
          "TEST_RUNS_PATH": "${TEST_RUNS_PATH_MIA_BA}"
        }
      },
      "github": {
        "url": "${GITHUB_MCP_URL}",
        "headers": {
          "Authorization": "${GITHUB_MCP_AUTH_HEADER}"
        }
      },
      "agile-studio": {
        "type": "streamableHttp",
        "url": "http://127.0.0.1:9121/mcp",
        "headers": {
          "Authorization": "Bearer mcp_pClGg2_YlJWZJgYyJS-A5vLM1vwUBIQ8"
        },
        "toolTimeout": 30,
        "enabledTools": [
          "*"
        ]
      }
    }
  }
}
