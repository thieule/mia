# Copy to `.env` in this directory (ai-pm/). Not committed.
# See ../core/EXAMPLE_.env for optional service-specific vars.

# --- OpenRouter ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# --- Google Gemini (optional) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Web search (Brave) ---
BRAVE_API_KEY=

# --- ai-tools MCP (registry + pytest) ---
AI_TOOL_SECRET=change-me-to-a-long-random-secret

# --- GitHub MCP ---
GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/
GITHUB_TOKEN=

# --- Pytest MCP: JSON reports (default: workspace/agent/test-runs/) ---
# TEST_RUNS_PATH_MIA_PM=

# --- Discord (Mia PM) ---
DISCORD_BOT_TOKEN_MIA_PM=
DISCORD_ADMIN_USER_IDS=
