# Sao thành .env trong cùng thư mục (không commit). Dùng cho main.py, working_queue_webhook.py, v.v.

# --- Workflow runtime HTTP (python working_queue_webhook.py) — MỘT bí mật kết nối ---
# Client gửi giá trị này CHỈ trong POST /v1/sessions { "secret": "..." }; mọi API sau dùng session_key trả về.
# (Tùy chọn v1: WORKING_QUEUE_WEBHOOK_BEARER_TOKEN / WORKFLOW_STUDIO_BOOTSTRAP_SECRET vẫn đọc như alias cũ)
WORKFLOW_RUNTIME_CONNECT_SECRET=change-me-long-random-secret

# URL công khai (reverse proxy) — discovery trả về đúng host cho client
# WORKFLOW_RUNTIME_PUBLIC_BASE_URL=https://runtime.example.com

# Webhook path + map agent (không đổi)
# WORKING_QUEUE_WEBHOOK_AGENTS_FILE=working_queue_webhook_agents.json
# WORKING_QUEUE_SUBDIR=working_queue
# Event workflow YAML (runtime đọc rules event -> action -> agent):
# Mặc định: workflows/agile-studio.events.workflow.yaml
# WORKFLOW_RUNTIME_EVENT_WORKFLOW_FILE=workflows/agile-studio.events.workflow.yaml

# --- Catalog tên/role (tùy chọn) ---
# WORKFLOW_STUDIO_CATALOG_FILE=studio_agents_catalog.json
# WORKFLOW_STUDIO_SESSION_TTL_DAYS=30
